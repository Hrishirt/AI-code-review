# ─────────────────────────────────────────────────────────────────────────────
# AI Code Review — Environment Variables
# Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Your Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token (or GitHub App token) with:
#   - repo scope (for fetching diffs from private repos)
#   - pull_requests write scope (for posting review comments)
GITHUB_TOKEN=ghp_...

# Secret used to verify GitHub webhook payloads (HMAC-SHA256)
# Set this in your GitHub repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=code_review

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
